# .env.example — copy this file to .env and fill in your values.
# Do NOT commit your actual .env file (it is listed in .gitignore).

# ---------------------------------------------------------------------------
# Base44 — Axiom-60 app  (https://app.base44.com/apps/69c3204219e8e63b63a9e14e)
# ---------------------------------------------------------------------------

# Your Base44 API key.
# Obtain it from: Base44 app settings → API keys → Create new key
# When set, every /classify and /classify/batch response is automatically
# pushed to the Matchup entity in the Axiom-60 Base44 app.
BASE44_API_KEY=your_base44_api_key_here
